  "info": {
    "title": "API com Swagger",
    "description": "Documentação automática da API com Swagger",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "joao@email.com",
            "description": "Email para cadastro do novo usuário"
          },
          "password": {
            "type": "string",
            "example": "senhaSegura123",
            "description": "Senha para o novo usuário (mínimo 6 caracteres)"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "joao@email.com",
            "description": "Email do usuário cadastrado"
          },
          "password": {
            "type": "string",
            "example": "senhaSegura123",
            "description": "Senha em formato texto plano"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateTripDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Férias de Verão",
            "description": "Título ou nome da viagem"
          },
          "destination": {
            "type": "string",
            "example": "Rio de Janeiro",
            "description": "Destino da viagem"
          },
          "startDate": {
            "type": "string",
            "example": "2026-12-20T00:00:00.000Z",
            "description": "Data de início da viagem",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "example": "2027-01-05T00:00:00.000Z",
            "description": "Data de término da viagem",
            "format": "date-time"
          },
          "userId": {
            "type": "number",
            "example": 1,
            "description": "ID do usuário associado à viagem"
          }
        },
        "required": [
          "title",
          "destination",
          "startDate",
          "endDate",
          "userId"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "nicolas@email.com",
            "description": "Email do usuário"
          },
          "password": {
            "type": "string",
            "example": "mypassword123",
            "description": "Senha do usuário (mínimo 6 caracteres)"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
